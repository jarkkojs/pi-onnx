{
  "name": "pi-onnx",
  "version": "0.1.0",
  "description": "Run Hugging Face onnx-community models locally inside pi: registers a chat provider for ONNX text-generation models and a set of tools (embeddings, classification, ASR) backed by @huggingface/transformers and onnxruntime-node.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-provider",
    "coding-agent",
    "onnx",
    "onnxruntime",
    "huggingface",
    "onnx-community",
    "transformers",
    "local-inference"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "check": "tsc --noEmit",
    "build": "echo 'no build step — extension loads ./src/index.ts directly'",
    "clean": "echo 'nothing to clean'"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@types/node": "^22.0.0",
    "typebox": "^1.1.34",
    "typescript": "^5.6.0"
  }
}
